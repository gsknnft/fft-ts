{
  "name": "@gsknnft/fft-ts",
  "version": "1.2.0",
  "author": "gsknnft",
  "description": "Modern Float64-focused FFT toolkit for TypeScript and Node.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "pnpm run clean && vite build && pnpm run build:types",
    "build:vite": "vite build",
    "build:types": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist/types && shx rm -f dist/tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "mocha tests/**/*.test.js",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm run typecheck && pnpm run build && pnpm run test && pnpm run pack:check"
  },
  "devDependencies": {
    "shx": "^0.4.0",
    "@types/mocha": "^10.0.10",
    "eslint": "^9.39.1",
    "fourier-transform": "^1.1.2",
    "mocha": "^8.2.1",
    "ts-node": "^8.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "bit-twiddle": "1.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gsknnft/fft-ts.git"
  }
}
