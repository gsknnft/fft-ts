{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "esnext",
    "strict": false,
    "target": "ESNext",
    "composite": true,
    "declaration": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "typeRoots": [
      "../../src/types"
    ],
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
    ]
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "node_modules",
    "./dist",
    "./wip",
    "./tests",
    "**/*.test.ts"
  ]
}
